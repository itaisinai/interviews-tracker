DATABASE_URL=
SOURCE_DATABASE_URL=
FRONTEND_ORIGIN=http://localhost:5173
PORT=4000

# Development Mode Authentication Bypass
# WARNING: Only use in local development. Never enable in production.
# When enabled, bypasses Auth0 and uses a test user for all requests.
# Backend will refuse to start if enabled with non-local database.
DEV_MODE_BYPASS_AUTH=false
DEV_MODE_USER_EMAIL=dev@local.test

VITE_DEV_MODE_BYPASS_AUTH=false
VITE_DEV_MODE_USER_EMAIL=dev@local.test
VITE_API_BASE_URL=http://localhost:4000/api

VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
VITE_ALLOWED_EMAIL=

AUTH0_DOMAIN=
AUTH0_AUDIENCE=
ALLOWED_EMAIL=

AI_PROVIDER=openai
OPENAI_API_KEY=
