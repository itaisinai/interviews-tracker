# For production/remote database:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# For local Docker database (required for dev mode):
DATABASE_URL=postgresql://jobcrm:jobcrm@localhost:5433/jobcrm
SOURCE_DATABASE_URL=
FRONTEND_ORIGIN=http://localhost:5173
PORT=4000

# Development Mode Authentication Bypass
# WARNING: Only use in local development. Never enable in production.
# When enabled, bypasses Auth0 and uses a test user for all requests.
# Backend will refuse to start if enabled with non-local database.
DEV_MODE_BYPASS_AUTH=false
DEV_MODE_USER_EMAIL=dev@local.test

VITE_DEV_MODE_BYPASS_AUTH=false
VITE_DEV_MODE_USER_EMAIL=dev@local.test
VITE_API_BASE_URL=http://localhost:4000/api

VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
VITE_ALLOWED_EMAIL=

AUTH0_DOMAIN=
AUTH0_AUDIENCE=
ALLOWED_EMAIL=

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Person research LLM fallback (when Exa fails)
PERPLEXITY_API_KEY=

# Telegram bot configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_BACKEND_WEBHOOK_URL=http://localhost:4000/webhooks/opportunities/telegram
OPPORTUNITY_WEBHOOK_SECRET=
WEB_APP_BASE_URL=http://localhost:3000

# Telegram authorization (comma-separated list)
# At least one must be configured for query feature to work
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_ALLOWED_CHAT_IDS=

COMPANY_RESEARCH_PROVIDER=exa
EXA_API_KEY=

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:4000/api/gmail/callback
GMAIL_TOKEN_ENCRYPTION_KEY=
