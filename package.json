{
  "name": "interviews-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "concurrently \"yarn dev:api\" \"yarn dev:web\"",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:web": "vite --config apps/web/vite.config.ts --host 0.0.0.0",
    "env:check": "node scripts/env-check.mjs",
    "build": "yarn prisma:generate && yarn build:api && yarn build:web",
    "build:storybook": "HOME=/tmp/storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook build -c apps/web/.storybook",
    "build:api": "tsc -p apps/api/tsconfig.json && node scripts/clean-package-js.mjs",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "storybook": "HOME=/tmp/storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -c apps/web/.storybook",
    "test:visual": "node scripts/visual-docker.mjs",
    "test:visual:update": "UPDATE_SNAPSHOTS=1 node scripts/visual-docker.mjs",
    "test:visual:local": "node scripts/test-visual-ci.mjs",
    "test:visual:ci": "node scripts/test-visual-ci.mjs",
    "test:visual:update:ci": "UPDATE_SNAPSHOTS=1 node scripts/test-visual-ci.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "start:api": "node scripts/start-api.mjs",
    "start:web": "vite preview --config apps/web/vite.config.ts --host 0.0.0.0"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.17.0",
    "@hookform/resolvers": "^3.10.0",
    "@interviews-tracker/design-system": "workspace:*",
    "@prisma/client": "5.22.0",
    "@tanstack/react-query": "^5.95.0",
    "@tanstack/react-table": "^8.21.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^6.30.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "prisma": "5.22.0",
    "storybook": "8.6.18",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.1"
  },
  "packageManager": "yarn@4.9.2"
}
