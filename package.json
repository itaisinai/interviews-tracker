{
  "name": "interviews-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "concurrently \"yarn dev:api\" \"yarn dev:web\"",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:web": "vite --config apps/web/vite.config.ts --host 0.0.0.0",
    "build": "yarn prisma:generate && yarn build:api && yarn build:web",
    "build:api": "tsc -p apps/api/tsconfig.json",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "start:api": "node dist/api/server.js",
    "start:web": "vite preview --config apps/web/vite.config.ts --host 0.0.0.0"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.17.0",
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "5.22.0",
    "@tanstack/react-query": "^5.95.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^6.30.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
