{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web/src",
  "implicitDependencies": ["core", "ai", "integrations", "api-client", "design-system"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/web"],
      "options": {
        "command": "vite build --config apps/web/vite.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/web/tsconfig.json --noEmit"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite --config apps/web/vite.config.ts --host 0.0.0.0"
      }
    },
    "visual": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn test:visual:ci"
      }
    }
  }
}
