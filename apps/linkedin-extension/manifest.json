{
  "manifest_version": 3,
  "name": "Interviews Tracker LinkedIn Import",
  "version": "0.1.0",
  "description": "Import visible LinkedIn jobs into Interviews Tracker.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://www.linkedin.com/jobs/view/*",
    "https://www.linkedin.com/jobs/search/*",
    "http://localhost:4000/*",
    "https://interviews-tracker-api.onrender.com/*"
  ],
  "action": {
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/view/*",
        "https://www.linkedin.com/jobs/search/*"
      ],
      "js": [
        "src/content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/extractor.js"
      ],
      "matches": [
        "https://www.linkedin.com/*"
      ]
    }
  ]
}
