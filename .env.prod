# Production Environment Variables - TEMPLATE ONLY
# This file contains placeholder values for documentation purposes.
# Real production secrets are stored in AWS Parameter Store at:
# /interviews-tracker/prod/*

# Database

# Auth0
AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_AUDIENCE="https://interviews-tracker-api.com"
ALLOWED_EMAIL="your@email.com"

# Frontend
FRONTEND_ORIGIN="https://interviews-tracker.vercel.app"
PORT=4000

# Vite (Frontend Environment Variables)
VITE_API_BASE_URL="https://interviews-api.trackylab.com/api"
VITE_AUTH0_DOMAIN="your-tenant.us.auth0.com"
VITE_AUTH0_CLIENT_ID="your-auth0-client-id"
VITE_AUTH0_AUDIENCE="https://interviews-tracker-api.com"
VITE_ALLOWED_EMAIL="your@email.com"

# AI Provider
AI_PROVIDER=openai
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_MODEL=gpt-4o-mini

# Additional AI APIs
PERPLEXITY_API_KEY="pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
COMPANY_RESEARCH_PROVIDER=exa
EXA_API_KEY="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Gmail OAuth
GMAIL_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxx"
GMAIL_REDIRECT_URI="https://interviews-api.trackylab.com/api/gmail/callback"
GMAIL_TOKEN_ENCRYPTION_KEY="your-64-character-hex-encryption-key-here-xxxxxxxxxxxxxxxxxx"

# Telegram Bot
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-xxxxxxxxx"
TELEGRAM_WEBHOOK_SECRET_TOKEN="your-webhook-secret-token-64-characters-xxxxxxxxxxxxxxxxxxxxxxx"
TELEGRAM_BACKEND_WEBHOOK_URL="https://interviews-api.trackylab.com/webhooks/opportunities/telegram"
OPPORTUNITY_WEBHOOK_SECRET="your-opportunity-webhook-secret-64-characters-xxxxxxxxxxxxxxx"

# Sentry
SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXXXXXXXXXXXXX.ingest.de.sentry.io/XXXXXXXXXXXXXXXX"
SENTRY_ENVIRONMENT=production

# Chrome Extension
CHROME_EXTENSION_ORIGIN="chrome-extension://your-extension-id-here"
