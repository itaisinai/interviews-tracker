generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PipelineType {
  POTENTIAL
  ACTIVE_PROCESS
  ARCHIVED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
  MAYBE
}

enum JobStatus {
  RESEARCH_LEAD
  TO_APPLY
  APPLIED
  RECRUITER_REACHED_OUT
  PHONE_SCHEDULED
  PHONE_DONE
  TECHNICAL_SCHEDULED
  TECHNICAL_DONE
  HOME_ASSIGNMENT
  ASSIGNMENT_SUBMITTED
  FINAL_STAGE
  OFFER
  REJECTED
  PAUSED
  NOT_RELEVANT
}

enum InteractionStatus {
  SCHEDULED
  DONE
  REJECTED
  CANCELLED
  NEEDS_FOLLOW_UP
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum OfferStatus {
  NOT_DISCUSSED
  DISCUSSED
  VERBAL_OFFER
  WRITTEN_OFFER
  ACCEPTED
  DECLINED
}

enum GmailMessageStateStatus {
  USED
  HIDDEN
}

model JobOpportunity {
  id                     String                  @id @default(cuid())
  ownerEmail             String
  slug                   String
  companyName            String
  companySearchName      String?
  roleTitle              String
  pipelineType           PipelineType
  status                 JobStatus
  priority               Priority
  referrerOrConnection   String?
  source                 String?
  jobUrl                 String?
  linkedinUrl            String?
  nextStep               String?
  notes                  String?
  employeesRangeId       String?
  companyStageId         String?
  workModelId            String?
  location               String?
  funding                String?
  companyDescription     String?
  productDescription     String?
  customersTraction      String?
  techStack              String?
  backendFrontendSplit   String?
  compensationNotes      String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  employeesRange         CompanySizeOption?      @relation(fields: [employeesRangeId], references: [id])
  companyStage           CompanyStageOption?     @relation(fields: [companyStageId], references: [id])
  workModel              WorkModelOption?        @relation(fields: [workModelId], references: [id])
  domains                JobOpportunityDomain[]
  interactions           Interaction[]
  notesList              Note[]
  tasks                  Task[]
  compensation           Compensation?
  contacts               Person[]

  @@unique([ownerEmail, slug])
  @@unique([ownerEmail, companyName, roleTitle])
  @@index([ownerEmail])
  @@index([ownerEmail, pipelineType])
  @@index([ownerEmail, status])
  @@index([pipelineType])
  @@index([status])
  @@index([priority])
}

model Interaction {
  id               String              @id @default(cuid())
  ownerEmail       String
  slug             String
  jobOpportunityId String
  date             DateTime
  endDate          DateTime?
  type             String
  stage            String?
  status           InteractionStatus
  personName       String?
  personRole       String?
  agenda           String?
  meetingLink      String?
  gmailMessageId   String?             // Deprecated: kept for backward compatibility, use attachedEmails instead
  notes            String?
  outcome          String?
  followUp         String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  jobOpportunity   JobOpportunity      @relation(fields: [jobOpportunityId], references: [id], onDelete: Cascade)
  notesList        Note[]
  tasks            Task[]
  attachedEmails   InteractionEmail[]    // Multiple emails can be attached to one interaction
  feedback         InteractionFeedback[] // Multiple feedback notes can be attached to one interaction

  @@unique([ownerEmail, slug])
  @@index([ownerEmail])
  @@index([ownerEmail, date])
  @@index([date])
  @@index([status])
  @@index([ownerEmail, status, endDate])
}

model InteractionEmail {
  id             String      @id @default(cuid())
  interactionId  String
  gmailMessageId String
  subject        String?
  from           String?
  receivedDate   DateTime?
  extractedData  Json?       // Stores what was extracted from this email (for audit/rollback)
  attachedAt     DateTime    @default(now())
  interaction    Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  @@unique([interactionId, gmailMessageId]) // Can't attach the same email twice
  @@index([interactionId])
  @@index([gmailMessageId])
}

model InteractionFeedback {
  id            String      @id @default(cuid())
  interactionId String
  content       String      // Raw feedback text (WhatsApp, text, etc)
  source        String?     // e.g., "WhatsApp", "Manual"
  extractedData Json?       // Stores AI extraction metadata
  attachedAt    DateTime    @default(now())
  interaction   Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  @@index([interactionId])
}

model Note {
  id               String          @id @default(cuid())
  ownerEmail       String
  jobOpportunityId String?
  interactionId    String?
  title            String
  content          String
  category         String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  jobOpportunity   JobOpportunity? @relation(fields: [jobOpportunityId], references: [id], onDelete: Cascade)
  interaction      Interaction?    @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  @@index([ownerEmail])
}

model Task {
  id               String          @id @default(cuid())
  ownerEmail       String
  jobOpportunityId String?
  interactionId    String?
  title            String
  status           TaskStatus
  priority         Priority
  dueDate          DateTime?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  jobOpportunity   JobOpportunity? @relation(fields: [jobOpportunityId], references: [id], onDelete: Cascade)
  interaction      Interaction?    @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  @@index([ownerEmail])
  @@index([ownerEmail, status])
  @@index([status])
  @@index([dueDate])
}

model Compensation {
  id                 String         @id @default(cuid())
  ownerEmail         String
  jobOpportunityId   String         @unique
  baseSalary         String?
  equity             String?
  bonus              String?
  signingBonus       String?
  benefits           String?
  vacationDays       String?
  workModelNotes     String?
  negotiationNotes   String?
  offerStatus        OfferStatus    @default(NOT_DISCUSSED)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  jobOpportunity     JobOpportunity @relation(fields: [jobOpportunityId], references: [id], onDelete: Cascade)

  @@index([ownerEmail])
}

model CompanySizeOption {
  id            String           @id @default(cuid())
  label         String           @unique
  createdAt     DateTime         @default(now())
  opportunities JobOpportunity[]
}

model CompanyStageOption {
  id            String           @id @default(cuid())
  label         String           @unique
  createdAt     DateTime         @default(now())
  opportunities JobOpportunity[]
}

model DomainOption {
  id            String                 @id @default(cuid())
  label         String                 @unique
  createdAt     DateTime               @default(now())
  opportunities JobOpportunityDomain[]
}

model WorkModelOption {
  id            String           @id @default(cuid())
  label         String           @unique
  createdAt     DateTime         @default(now())
  opportunities JobOpportunity[]
}

model InteractionTypeOption {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())
}

model InterviewStageOption {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())
}

model JobOpportunityDomain {
  ownerEmail       String
  jobOpportunityId String
  domainId         String
  jobOpportunity   JobOpportunity @relation(fields: [jobOpportunityId], references: [id], onDelete: Cascade)
  domain           DomainOption   @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@id([jobOpportunityId, domainId])
  @@index([ownerEmail])
}

model GmailConnection {
  id                    String   @id @default(cuid())
  auth0Email            String   @unique
  googleEmail           String?
  refreshTokenEncrypted String
  scope                 String?
  lastError             String?
  needsReconnect        Boolean  @default(false)
  connectedAt           DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model GmailMessageState {
  id               String                  @id @default(cuid())
  auth0Email       String
  messageId        String
  jobOpportunityId String?
  status           GmailMessageStateStatus
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([auth0Email, messageId])
  @@index([auth0Email, status])
  @@index([jobOpportunityId])
}

model Person {
  id               String           @id @default(cuid())
  name             String
  email            String?
  linkedinUrl      String?
  title            String?
  company          String?
  avatarUrl        String?
  jobOpportunityId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  research         PersonResearch?
  jobOpportunity   JobOpportunity?  @relation(fields: [jobOpportunityId], references: [id], onDelete: SetNull)

  @@unique([email])
  @@unique([linkedinUrl])
  @@index([name, company])
  @@index([jobOpportunityId])
  @@index([name, jobOpportunityId])
}

model PersonResearch {
  id          String                    @id @default(cuid())
  personId    String                    @unique
  about       String?
  experience  Json?
  education   Json?
  skills      Json?
  sources     Json?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  person      Person                    @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model WrongPersonCandidate {
  id            String   @id @default(cuid())
  opportunityId String
  searchContext String   // What name/company/title was being searched
  personName    String
  linkedinUrl   String?
  company       String?
  title         String?
  avatarUrl     String?
  rejectedAt    DateTime @default(now())
  notes         String?

  @@unique([opportunityId, linkedinUrl])
  @@index([opportunityId])
  @@index([linkedinUrl])
}
