{
  "name": "ai",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/ai/src",
  "implicitDependencies": ["core"],
  "targets": {
    "build": { "executor": "nx:run-commands", "outputs": ["{projectRoot}/dist"], "options": { "command": "tsc -p packages/ai/tsconfig.json" } },
    "typecheck": { "executor": "nx:run-commands", "options": { "command": "tsc -p packages/ai/tsconfig.json --noEmit" } },
    "dev": { "executor": "nx:run-commands", "options": { "command": "tsc -p packages/ai/tsconfig.json --watch --preserveWatchOutput" } }
  }
}
