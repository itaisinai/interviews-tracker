{
  "name": "design-system",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/design-system/src",
  "targets": {
    "build": { "executor": "nx:run-commands", "outputs": ["{projectRoot}/dist"], "options": { "command": "tsc -p packages/design-system/tsconfig.json && node scripts/copy-package-assets.mjs packages/design-system" } },
    "typecheck": { "executor": "nx:run-commands", "options": { "command": "tsc -p packages/design-system/tsconfig.json --noEmit" } },
    "dev": { "executor": "nx:run-commands", "options": { "command": "tsc -p packages/design-system/tsconfig.json --watch --preserveWatchOutput" } }
  }
}
