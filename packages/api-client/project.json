{
  "name": "api-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/api-client/src",
  "implicitDependencies": ["core", "ai", "integrations"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "cd packages/api-client && tsup"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/api-client/tsconfig.json --noEmit"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd packages/api-client && tsup --watch"
      }
    }
  }
}
