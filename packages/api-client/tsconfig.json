{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "paths": {
      "@interviews-tracker/ai": ["../ai/dist/index.d.ts"],
      "@interviews-tracker/core": ["../core/dist/index.d.ts"],
      "@interviews-tracker/integrations": ["../integrations/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "dist"]
}
