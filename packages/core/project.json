{
  "name": "core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/core/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": { "command": "cd packages/core && tsup" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p packages/core/tsconfig.json --noEmit" }
    },
    "dev": { "executor": "nx:run-commands", "options": { "command": "cd packages/core && tsup --watch" } }
  }
}
